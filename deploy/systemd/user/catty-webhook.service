[Unit]
Description=Catty GitHub webhook (user, home directory)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/devops
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/devops/deploy/webhook.home.env
ExecStart=%h/devops/.venv/bin/uvicorn webhook.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
