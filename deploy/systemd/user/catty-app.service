[Unit]
Description=Catty app (user, home directory)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/devops
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/devops/.env
ExecStart=%h/devops/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
