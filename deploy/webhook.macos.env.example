# Copy to deploy/webhook.macos.env and adjust if needed. Do not commit the local env file.
WEBHOOK_SECRET=kozlov-secret
APP_DIR=/absolute/path/to/catty-reminders-app
APP_ENV_FILE=/absolute/path/to/catty-reminders-app/.env
DEPLOY_SCRIPT=/absolute/path/to/catty-reminders-app/scripts/deploy.sh
APP_RESTART_COMMAND=/absolute/path/to/catty-reminders-app/scripts/restart-catty-app-macos.sh
APP_SERVICE=none
RUN_TESTS=1
TEST_COMMAND=.venv/bin/python -m pytest tests/test_unit.py
