# Вариант B: деплой в домашний каталог (не /opt/catty).
# 1) Скопируй этот файл:  cp deploy/webhook.home.env.example deploy/webhook.home.env
# 2) Правь пути и секреты. Файл deploy/webhook.home.env в git не коммить.
#
# 3) User systemd (см. deploy/systemd/user/*.service):
#    mkdir -p ~/.config/systemd/user
#    cp deploy/systemd/user/catty-app.service ~/.config/systemd/user/
#    cp deploy/systemd/user/catty-webhook.service ~/.config/systemd/user/
#    # при необходимости поправь %h/devops если репозиторий не в ~/devops
#    systemctl --user daemon-reload
#    systemctl --user enable --now catty-app.service catty-webhook.service
#    loginctl enable-linger "$USER"
#
# 4) frpc по-прежнему с deploy/frpc.local.toml (локальные порты 8181 / 8080).

APP_DIR=/home/danila/devops
APP_ENV_FILE=/home/danila/devops/.env
APP_SERVICE=none
APP_RESTART_COMMAND=/usr/bin/systemctl --user restart catty-app.service

# Секрет вебхука GitHub (тот же, что в настройках Webhook на GitHub):
# WEBHOOK_SECRET=...

# Опционально для статусов в PR:
# GITHUB_TOKEN=...
